# Copy to .env and adjust as needed.

# --- Providers ---
# Chat: "ollama" (local) or "gemini" (Google Generative AI, cloud)
# Embeddings: "ollama" (local) or "huggingface" (sentence-transformers, cloud)
RAG_LLM_PROVIDER=ollama
RAG_EMBED_PROVIDER=ollama

# Ollama models (used when provider=ollama)
RAG_CHAT_MODEL=llama3.2
RAG_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# Gemini (used when RAG_LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here
RAG_GEMINI_MODEL=gemini-2.5-flash

# Hugging Face embeddings (used when RAG_EMBED_PROVIDER=huggingface)
RAG_HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Default document source (a blog post, LangChain-style demo)
RAG_SOURCE_URL=https://lilianweng.github.io/posts/2023-06-23-agent/

# Chunking
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# Storage
RAG_CHROMA_DIR=.chroma

# --- LangSmith tracing (optional) ---
# See every LLM / retriever / chain call at https://smith.langchain.com
# Get an API key from your LangSmith account (Settings -> API Keys).
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_your_key_here
LANGSMITH_PROJECT=rag-from-scratch
