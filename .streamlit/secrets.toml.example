# Streamlit Cloud secrets template.
#
# On Streamlit Community Cloud, open your app -> Settings -> Secrets and paste
# the contents below (without this comment header is fine). DO NOT commit a
# real secrets.toml with your key — only this example belongs in git.

# Use cloud providers (no Ollama on Streamlit Cloud)
RAG_LLM_PROVIDER = "gemini"
RAG_EMBED_PROVIDER = "huggingface"

# Google Gemini — get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY = "your_google_api_key_here"
RAG_GEMINI_MODEL = "gemini-1.5-flash"

# Hugging Face embeddings (runs locally via sentence-transformers, no key needed)
RAG_HF_EMBED_MODEL = "sentence-transformers/all-MiniLM-L6-v2"

# Optional: LangSmith tracing
# LANGSMITH_TRACING = "true"
# LANGSMITH_ENDPOINT = "https://api.smith.langchain.com"
# LANGSMITH_API_KEY = "lsv2_your_key_here"
# LANGSMITH_PROJECT = "rag-from-scratch"
